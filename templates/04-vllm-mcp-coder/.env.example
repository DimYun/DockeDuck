# ─── Model ────────────────────────────────────────────────────────────────────
# Default is the BEST performer in our 6 GB benchmark (experiments/RESULTS.md): Qwen3-4B-AWQ
# scored 93% local / 100% with one rescue, and a perfect 5/5 with ENABLE_THINKING=true.
# Ask the MCP tool `recommend_setup` to pick the ideal model + context for YOUR hardware.
#
# AWQ 4-bit quantized models (recommended for ≤8 GB GPU, set --quantization awq):
#   Qwen/Qwen3-4B-AWQ                      ~2.5 GB VRAM  ← default, best quality (thinking-capable)
#   Qwen/Qwen2.5-Coder-3B-Instruct-AWQ     ~2.0 GB VRAM  code-focused, 3× bigger context (24K)
#   Qwen/Qwen2.5-Coder-1.5B-Instruct-AWQ   ~1.0 GB VRAM  fastest / smallest GPU
#   Qwen/Qwen2.5-Coder-7B-Instruct-AWQ     ~4.0 GB VRAM  needs >6 GB with usable context
#   (QuantTrio/Qwen3.5-4B-AWQ is BF16 mislabeled as AWQ — do NOT use on ≤8 GB GPU)
#
# Full-precision (fp16/bf16) needs ~2× param count in VRAM — avoid on ≤8 GB GPUs.
VLM_MODEL=Qwen/Qwen3-4B-AWQ

# HuggingFace token — only needed for gated models; Qwen is public, leave empty
HF_TOKEN=

# ─── Offline mode ─────────────────────────────────────────────────────────────
# First run: model downloads to the mounted HF cache (see `make start` volume).
# After the download completes, set this to 1 to block all outbound HF requests.
HF_HUB_OFFLINE=0

# ─── vLLM server (internal — not exposed outside the container) ───────────────
VLLM_PORT=8001
VLM_GPU_MEMORY_UTILIZATION=0.85
# Max context. Set to the largest that fits your VRAM — it is KV-cache bound, so it
# depends on the model's GQA KV-head count, NOT just parameter size. Measured on 6 GB:
#   Qwen2.5-Coder-1.5B-AWQ (2 KV heads)  32768
#   Qwen2.5-Coder-3B-AWQ   (2 KV heads)  24576
#   Qwen3-4B-AWQ           (8 KV heads)   8192   (4× KV/token — OOMs above ~10K)
VLM_MAX_MODEL_LEN=8192
# Required for AWQ models; leave empty for full-precision models.
# --enforce-eager disables CUDA-graph capture (avoids load-time OOM on ≤6 GB GPUs, as with
# the default Qwen3-4B). Remove it on GPUs with >8 GB VRAM for faster throughput.
VLM_EXTRA_ARGS=--quantization awq --enforce-eager

# ─── MCP server ───────────────────────────────────────────────────────────────
MCP_PORT=8000
# Transport: sse (default, for Docker/remote) | stdio (for direct local use)
MCP_TRANSPORT=sse

# ─── write_and_fix loop ───────────────────────────────────────────────────────
# Maximum fix iterations before write_and_fix gives up
MAX_RETRIES=7

# ─── Code validation sandbox ─────────────────────────────────────────────────
CODE_TIMEOUT=30

# ─── Generation ──────────────────────────────────────────────────────────────
TEMPERATURE=0.1
# Output-token budget. Keep MAX_TOKENS well below VLM_MAX_MODEL_LEN — with the fix loop,
# prompt+history+MAX_TOKENS must fit the context or vLLM returns HTTP 400. At the 8192
# ceiling (Qwen3-4B) use 4096, especially with thinking on.
MAX_TOKENS=4096
# Extended thinking (Qwen3 / Qwen3.5). Benchmarks (experiments.md §6.8): thinking gives NO
# gain and just slows generation for a strong model, but LIFTS a capable-enough local model
# — Qwen3-4B went 4/5 → 5/5 (cloud parity) with it on. Try it on Qwen3-family models; it is
# a no-op on Qwen2.5-Coder (no <think>). On a 6 GB GPU at 8192 ctx it can be flaky (KV
# pressure → occasional 400s); keep MAX_TOKENS=4096 there.
ENABLE_THINKING=false

# ─── Cloud API (only needed for exp-bench-cloud / exp-bench-full / exp-custom-*) ─
# Leave empty if you only run local VLM benchmarks.
ANTHROPIC_API_KEY=
