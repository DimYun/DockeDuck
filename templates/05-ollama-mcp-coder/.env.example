# ─── Model ────────────────────────────────────────────────────────────────────
# Default is the BEST Ollama performer in our 6 GB benchmark (experiments/RESULTS.md):
# qwen2.5-coder:3b is fast and reaches 100% with one rescue. Ask the MCP tool
# `recommend_setup` to pick the ideal model + context for YOUR hardware.
# All models are auto-downloaded from the Ollama registry on first start.
#   qwen2.5-coder:3b     ~2 GB VRAM   ← default: fast, 100% with rescue
#   qwen2.5-coder:1.5b   ~1 GB VRAM   smallest GPU / CPU; still clears 3/5 tasks
#   qwen3.5:4b           ~3 GB VRAM   thinking-capable (ENABLE_THINKING); slower but 100% w/ rescue
#   qwen2.5-coder:7b     ~4 GB VRAM   stronger, needs >6 GB for a usable context
OLLAMA_MODEL=qwen2.5-coder:3b

# ─── Context window ───────────────────────────────────────────────────────────
# Passed to Ollama via the options field. Set to the largest that fits your VRAM (same
# for thinking and non-thinking — it is a KV-cache constraint). Measured on 6 GB:
#   qwen2.5-coder:1.5b / :3b   16384
#   qwen3.5:4b                 12288  (thinking needs headroom for the <think> trace)
OLLAMA_NUM_CTX=16384

# ─── Ports ────────────────────────────────────────────────────────────────────
MCP_PORT=8000
OLLAMA_PORT=11434

# ─── MCP server ───────────────────────────────────────────────────────────────
MCP_TRANSPORT=sse

# ─── write_and_fix loop ───────────────────────────────────────────────────────
MAX_RETRIES=7

# ─── Code validation sandbox ─────────────────────────────────────────────────
CODE_TIMEOUT=30

# ─── Generation ──────────────────────────────────────────────────────────────
TEMPERATURE=0.1
# Output-token budget (num_predict). For thinking models raise it (e.g. 6144) so the
# <think> trace + the code both fit, and keep OLLAMA_NUM_CTX comfortably larger.
MAX_TOKENS=4096
# Extended thinking. Native /api/chat honours think:false (the /v1 endpoint does NOT).
# Benchmarks (experiments.md §6.8): thinking clearly HELPS weaker local models — qwen3.5:4b
# went 66.6% → 86.8% (local) and its rescue reached 100% at half the cost. Worth enabling on
# qwen3.5:4b. No-op on qwen2.5-coder (no <think>). Raise MAX_TOKENS + OLLAMA_NUM_CTX with it.
ENABLE_THINKING=false

# ─── Cloud API (only needed for benchmarks) ───────────────────────────────────
ANTHROPIC_API_KEY=
