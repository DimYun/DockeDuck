# ─── ClearML experiment tracking ──────────────────────────────────────────────
# Copy this file to .env and paste your credentials (ClearML web app → Settings →
# Workspace → Create new credentials). Loaded by `make train` (--env-file .env).
# Leave blank to train without tracking.
CLEARML_API_ACCESS_KEY=
CLEARML_API_SECRET_KEY=
CLEARML_API_HOST=https://api.clear.ml
CLEARML_WEB_HOST=https://app.clear.ml
CLEARML_FILES_HOST=https://files.clear.ml

# ─── Weights & Biases (optional alternative) ─────────────────────────────────
# WANDB_API_KEY=
