# ─── Model ────────────────────────────────────────────────────────────────────
# fp16/bf16 (full precision) — needs ~2× the parameter count in GB:
#   Qwen/Qwen2.5-Coder-1.5B-Instruct  ~3 GB VRAM
#   Qwen/Qwen2.5-Coder-3B-Instruct    ~6 GB VRAM  (tight, may OOM on 6 GB GPU)
#
# AWQ 4-bit quantized — ~4× smaller weights, recommended for ≤8 GB GPU:
#   Qwen/Qwen2.5-Coder-1.5B-Instruct-AWQ   ~1 GB VRAM  + KV cache
#   Qwen/Qwen2.5-Coder-3B-Instruct-AWQ     ~2 GB VRAM  + KV cache  ← recommended
#   Qwen/Qwen2.5-Coder-7B-Instruct-AWQ     ~4 GB VRAM  + KV cache
# When using an AWQ model, set VLM_EXTRA_ARGS=--quantization awq below.
VLM_MODEL=Qwen/Qwen2.5-Coder-3B-Instruct-AWQ

# HuggingFace token — only needed for gated models; Qwen is public, leave empty
HF_TOKEN=

# ─── Offline mode ─────────────────────────────────────────────────────────────
# First run: model downloads to the mounted HF cache (see `make start` volume).
# After the download completes, set this to 1 to block all outbound HF requests.
HF_HUB_OFFLINE=0

# ─── vLLM server (internal — not exposed outside the container) ───────────────
VLLM_PORT=8001
VLM_GPU_MEMORY_UTILIZATION=0.85
VLM_MAX_MODEL_LEN=8192
# Required for AWQ models; leave empty for full-precision models
VLM_EXTRA_ARGS=--quantization awq

# ─── MCP server ───────────────────────────────────────────────────────────────
MCP_PORT=8000
# Transport: sse (default, for Docker/remote) | stdio (for direct local use)
MCP_TRANSPORT=sse

# ─── write_and_fix loop ───────────────────────────────────────────────────────
# Maximum fix iterations before write_and_fix gives up
MAX_RETRIES=7

# ─── Code validation sandbox ─────────────────────────────────────────────────
CODE_TIMEOUT=30

# ─── Generation ──────────────────────────────────────────────────────────────
TEMPERATURE=0.1
MAX_TOKENS=4096

# ─── Cloud API (only needed for exp-bench-cloud / exp-bench-full / exp-custom-*) ─
# Leave empty if you only run local VLM benchmarks.
ANTHROPIC_API_KEY=
