# Copy this file to .env and fill in your values.
# The Makefile loads .env automatically for all run/jupyter/shell targets.
# Never commit .env to git — it is in .gitignore.

# ── HuggingFace (model downloads, gated models like pyannote) ─────────────────
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Experiment tracking ────────────────────────────────────────────────────────
# CLEARML_API_HOST=https://api.community.clear.ml
# CLEARML_API_ACCESS_KEY=
# CLEARML_API_SECRET_KEY=

# WANDB_API_KEY=

# ── LLM gateway (e.g. LiteLLM proxy via SSH tunnel) ──────────────────────────
# LLM_API_BASE=http://localhost:9080/v1
# LLM_API_KEY=sk-xxxx
